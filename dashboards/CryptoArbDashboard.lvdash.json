{
  "datasets": [
    {
      "name": "24d79aa5",
      "displayName": "P1VolatilityHeatmap",
      "queryLines": [
        "SELECT\r\n",
        "    ticker,\r\n",
        "    date_format(event_timestamp, 'HH:mm') AS time_window,\r\n",
        "    volatility_pct\r\n",
        "FROM crp_arb_dev.gold.crypto_data_15m\r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 15 MINUTE\r\n",
        "ORDER BY event_timestamp DESC"
      ]
    },
    {
      "name": "5fd184a2",
      "displayName": "P1LiveWhaleAlerts",
      "queryLines": [
        "SELECT\r\n",
        "    ticker,\r\n",
        "    date_format(event_timestamp, 'HH:mm:ss') AS exact_time,\r\n",
        "    trading_volume,\r\n",
        "    close,\r\n",
        "    (trading_volume * close) AS usd_volume\r\n",
        "FROM crp_arb_dev.gold.crypto_data_15m\r\n",
        "WHERE (trading_volume * close) > 500000 \r\n",
        "ORDER BY event_timestamp DESC\r\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "5ec72c61",
      "displayName": "P1RealtimeMarketSentiment",
      "queryLines": [
        "SELECT\r\n",
        "    market_signal,\r\n",
        "    COUNT(*) AS signal_count\r\n",
        "FROM crp_arb_dev.gold.crypto_data_15m\r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 15 MINUTE\r\n",
        "GROUP BY market_signal"
      ]
    },
    {
      "name": "8a80f9b3",
      "displayName": "P1PriceVSVolumeCorrelation",
      "queryLines": [
        "SELECT \r\n",
        "    date_format(event_timestamp, 'HH:mm') AS time_window,\r\n",
        "    ticker,\r\n",
        "    close,\r\n",
        "    trading_volume\r\n",
        "FROM crp_arb_dev.gold.crypto_data_15m\r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 15 MINUTE\r\n",
        "ORDER BY event_timestamp ASC"
      ]
    },
    {
      "name": "9ec4e81e",
      "displayName": "P2TopPerformers",
      "queryLines": [
        "SELECT \r\n",
        "    ticker, \r\n",
        "    daily_performance_pct,\r\n",
        "    CASE WHEN daily_performance_pct > 0 THEN 'Positive' ELSE 'Negative' END AS trend\r\n",
        "FROM crp_arb_dev.gold.crypto_data_24h \r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 1 DAY \r\n",
        "ORDER BY daily_performance_pct DESC"
      ]
    },
    {
      "name": "474e14c1",
      "displayName": "P2TradingVolumeShare",
      "queryLines": [
        "SELECT \r\n",
        "    ticker, \r\n",
        "    SUM(trading_volume) AS total_volume \r\n",
        "FROM crp_arb_dev.gold.crypto_data_24h \r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 1 DAY \r\n",
        "GROUP BY ticker"
      ]
    },
    {
      "name": "1b42a7aa",
      "displayName": "P2AssetVolatilitySpread",
      "queryLines": [
        "SELECT \r\n",
        "    ticker, \r\n",
        "    (day_high - day_low) AS daily_range_usd \r\n",
        "FROM crp_arb_dev.gold.crypto_data_24h \r\n",
        "WHERE event_timestamp >= current_timestamp() - INTERVAL 1 DAY\r\n",
        "ORDER BY daily_range_usd DESC"
      ]
    },
    {
      "name": "9d270ac3",
      "displayName": "P2PriceTrend24h",
      "queryLines": [
        "SELECT \r\n",
        "    date_format(event_timestamp, 'MMM-dd HH:mm') AS time, \r\n",
        "    ticker, \r\n",
        "    close \r\n",
        "FROM crp_arb_dev.gold.crypto_data_24h \r\n",
        "ORDER BY event_timestamp ASC"
      ]
    }
  ],
